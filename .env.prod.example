# Salin ke .env di samping docker-compose.prod.yml lalu isi nilainya.
#   cp .env.prod.example .env
# JANGAN commit .env yang sudah terisi.

# Alamat publik. Domain -> HTTPS otomatis. Tanpa domain (uji) pakai :80
SITE_ADDRESS=:80
APP_URL=http://localhost

# Cloudflare Tunnel (opsional). Isi token tunnel dari dashboard Zero Trust
# (Networks -> Tunnels -> Create -> Cloudflared) agar service `tunnel` jalan.
# Routing public hostname diatur di dashboard: SITE_ADDRESS -> http://web:3010
TUNNEL_TOKEN=

# APP_KEY: buat sekali dengan:
#   docker run --rm ghcr.io/naz-haq/rps-api:latest php artisan key:generate --show
APP_KEY=

# Database (dipakai container db + api)
DB_ROOT_PASSWORD=ganti-password-root-kuat
DB_DATABASE=curriculum_service
DB_USERNAME=rps
DB_PASSWORD=ganti-password-user-kuat

# AI (opsional). Kosongkan bila belum pakai; set AI_FALLBACK_MOCK=true agar
# fitur AI tetap jalan dengan keluaran tiruan saat belum ada key.
AI_PROFILE=simulasi
AI_FALLBACK_MOCK=false
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
